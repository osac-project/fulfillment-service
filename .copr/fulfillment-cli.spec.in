%global debug_package %{nil}

Name: fulfillment-cli
Version: @version@
Release: 1%{?dist}
Summary: CLI for the OSAC Fulfillment API
License: ASL 2.0
URL: https://github.com/osac-project/fulfillment-service
Source: %{name}-%{version}.tar.gz

BuildRequires: golang

%description
CLI for OSAC Fulfillment API

%prep
%setup

%build
go build \
-ldflags="-X github.com/osac-project/fulfillment-service/internal/version.id=%{version}" \
./cmd/fulfillment-cli

%install
install -m 0755 -d %{buildroot}%{_bindir}
install -m 0755 fulfillment-cli %{buildroot}%{_bindir}

%files
%license LICENSE
%doc README.md
%{_bindir}/*

%changelog
* @date@ OSAC <noreply@redhat.com> - @version@
- Automatic build for version @version@.
